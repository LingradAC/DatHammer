<Window x:Class="DatHammer.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DatHammer"
        mc:Ignorable="d"
        Title="DatHammer" Height="450" Width="800">
    <Window.Resources>
        <RoutedUICommand x:Key="StringToolsWindow_Click"></RoutedUICommand>
        <RoutedUICommand x:Key="MainWindowWindow_Click"></RoutedUICommand>
    </Window.Resources>
    <Window.CommandBindings>
        <!--CommandBinding Command="{StaticResource StringToolsWindow_Click}" Executed="StringToolsWindow_Executed"></CommandBinding-->
        <!--CommandBinding Command="{StaticResource MainWindowWindow_Click}" Executed="MainWindowWindow_Executed"></CommandBinding-->
    </Window.CommandBindings>

    <Grid>
        <!--UserControl x:Name="MainContent"></UserControl-->

        <Grid x:Name="MainWindow" Visibility="Visible" Background="#FFFEFEFE">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Grid.ColumnSpan="3" Margin="1,1,1,0" Width="Auto" VerticalAlignment="Top" Height="25" Background="#FFF0F0F0" BorderThickness="1" BorderBrush="#FF2E2E2E">
                <Canvas Margin="1,1,1,0" Width="Auto" VerticalAlignment="Top" Height="25" Background="Transparent">
                    <Button Click="MainWindow_Click" Margin="1,0,0,0" Width="55" Content="Home" Height="23.3" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" Background="#FFFEFEFE" BorderBrush="#FF6D6D6D" BorderThickness="0.7,0.7,0.7,0"></Button>
                    <Button Click="StringTools_Click" Margin="60,1,0,0" Width="75" Content="String Tools" Height="20" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" Background="#FFE3E3E3" BorderBrush="#FF6D6D6D"></Button>
                </Canvas>
            </Border>

            <TextBlock Grid.Column="1" Text="AC Directory: " FontSize="16" Margin="20,30,140,0" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="0,0,0,0" Width="Auto" Height="22" />
            <TextBox Grid.Column="1" x:Name="ACPath" HorizontalAlignment="Right" VerticalAlignment="Top" Width="140" Height="22" FontSize="12" Margin="5,30,0,0" TextChanged="ACPath_TextChanged" />
            <Button Grid.Column="2" x:Name="PathDialog" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="22" Margin="5,30,20,0" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="PathDialog_Click" Content=". . ." FontWeight="Bold" FontSize="11"/>
            <Border Grid.ColumnSpan="3" Grid.Column="0" BorderBrush="DarkGray" BorderThickness="2" Height="auto" Width="auto" Margin="10, 300, 10, 10" CornerRadius="4,4,4,4">
                <ScrollViewer x:Name="ScrollViewerConsole" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="OutputConsole" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="auto" Height="auto" FontSize="14" Margin="0, 0, 0, 0" Text="{Binding ConsoleText}" Padding="5, 3, 5, 5" Cursor="IBeam" FontFamily="Segoe UI Variable Text" TextWrapping="Wrap" Background="WhiteSmoke" IsReadOnly="True" IsUndoEnabled="False" />
                </ScrollViewer>
            </Border>
            <!--Button x:Name="TestButton" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="22" Margin="20,60,20,20" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="TestButton_Click"/-->

            <TextBlock Grid.Column="0" Text="Add Image" FontSize="18" Margin="20,40,20,20" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" Width="Auto" Height="22" FontFamily="Palatino Linotype" FontWeight="Bold" />
            <Button x:Name="AddImageButton" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="22" Margin="20,65,20,20" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="AddImageButton_Click" Content="Add" FontSize="14"/>
            <TextBlock x:Name="ImagePathPlaceholder" Grid.Column="0" Text="Image Path" FontSize="12" Margin="90,65,0,0" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,3,0,0" Width="145" Height="22" Foreground="#FF595959" Background="White" />
            <TextBox Grid.Column="0" TextChanged="ImgPathInput_Changed" x:Name="ImgPath" HorizontalAlignment="Left" VerticalAlignment="Top" Width="145" Height="22" FontSize="12" Margin="90,65,0,0" Background="{x:Null}" />
            <Button Grid.Column="0" Grid.ColumnSpan="2" x:Name="ImgPathDialog" HorizontalAlignment="Left" VerticalAlignment="Top" Width="30" Height="22" Margin="240,65,20,0" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="ImgPathDialog_Click" Content=". . ." FontWeight="Bold" FontSize="11"/>
            <TextBlock x:Name="ImageIDPlaceholder" Grid.Column="0" Text="ID (last 6)" FontSize="12" Margin="20,90,0,0" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,3,0,0" Width="95" Height="22" Foreground="#FF595959" Background="White" />
            <TextBox Grid.Column="0" TextChanged="ImgIDInput_Changed" x:Name="ImgID" HorizontalAlignment="Left" VerticalAlignment="Top" Width="95" Height="22" FontSize="12" Margin="20,90,0,0" Background="{x:Null}" />
            <ComboBox x:Name="dropdownImageResize" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Top" Width="65" Height="22" Margin="205,90,0,0" IsEnabled="False" Visibility="Hidden">
                <ComboBoxItem Tag="ResizeTrue" Content="True (Resize Image)" IsSelected="True" FontSize="12" />
                <ComboBoxItem Tag="ResizeFalse" Content="False (Resize Image)" FontSize="12" />
            </ComboBox>
            <CheckBox x:Name="imageResize" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Top" Width="85" Height="22" Margin="185,90,0,0" Padding="0,0,0,0" Content="Resize Image" VerticalContentAlignment="Center" UseLayoutRounding="False" Background="White" BorderBrush="#FF424242" Foreground="Black" />
            <ComboBox x:Name="dropdownImageType" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="22" Margin="120,90,0,0" IsEnabled="False">
                <ComboBoxItem Tag="PFID_A8B8G8R8" Content="ABGR" IsSelected="True" FontSize="12" />
                <ComboBoxItem Tag="PFID_A8R8G8B8" Content="ARGB" FontSize="12" />
                <ComboBoxItem Tag="PFID_CUSTOM_RAW_JPEG" Content="JPG" FontSize="12" />
                <ComboBoxItem Tag="PFID_INDEX16" Content="INDEX16" FontSize="12" />
                <ComboBoxItem Tag="PFID_R8G8B8" Content="RGB" FontSize="12" />
                <ComboBoxItem Tag="PFID_DXT1" Content="DXT1" FontSize="12" />
                <ComboBoxItem Tag="PFID_DXT2" Content="DXT2" FontSize="12" />
                <ComboBoxItem Tag="PFID_DXT3" Content="DXT3" FontSize="12" />
                <ComboBoxItem Tag="PFID_DXT4" Content="DXT4" FontSize="12" />
                <ComboBoxItem Tag="PFID_DXT5" Content="DXT5" FontSize="12" />
            </ComboBox>

            <Button x:Name="FontButton" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="22" Margin="20,220,20,20" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="FontTesting" Content="Font" FontSize="14"/>
            <Button x:Name="LayoutButton" HorizontalAlignment="Left" VerticalAlignment="Top" Width="Auto" Height="Auto" Margin="20,260,20,20" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="CreateLayout" Content="Create Layouts" FontSize="14" Padding="5,4,5,4" />

            <ComboBox x:Name="dropdownLayout" SelectionChanged="dropdownLayout_SelectionChanged" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Left" VerticalAlignment="Top" Width="120" Height="28" Margin="130,260,0,0" IsEnabled="True" Padding="5,4,5,4">

            </ComboBox>
            <Border x:Name="LayoutInfoBorder" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" Grid.RowSpan="3" HorizontalAlignment="Right" VerticalAlignment="Top" Width="150" Height="240" BorderBrush="#000000" BorderThickness="1" Margin="0,56,350,0" Panel.ZIndex="0" ClipToBounds="True">
                <Canvas x:Name="LayoutInfoWindow" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" Grid.RowSpan="3" HorizontalAlignment="Right" VerticalAlignment="Top" Width="150" Height="240" Margin="0,0,0,0" Panel.ZIndex="0" ClipToBounds="True" UseLayoutRounding="False">
                    <Canvas x:Name="TestCanvas" HorizontalAlignment="Left" VerticalAlignment="Top" Width="146" Height="20" Margin="2,2,2,2" Panel.ZIndex="0" ClipToBounds="True">
                        <TextBlock x:Name="TestText" Margin="2,1,0,0" Width="100" Height="18"></TextBlock>
                        <TextBox x:Name="TestTextBox" Canvas.Right="1" Canvas.Bottom="1" Width="40" Height="18" FontSize="12"></TextBox>
                    </Canvas>
                </Canvas>
            </Border>
            <Frame x:Name="LayoutWindow" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="0" Grid.RowSpan="3" HorizontalAlignment="Right" VerticalAlignment="Top" Width="320" Height="240" BorderBrush="#000000" BorderThickness="1" Margin="0,56,20,0" Panel.ZIndex="-3" ClipToBounds="True" NavigationUIVisibility="Hidden" IsTabStop="False" >

            </Frame>
        </Grid>

        <Grid x:Name="StringTools" Visibility="Collapsed" Background="#FFFEFEFE">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Grid.ColumnSpan="3" Margin="1,1,1,0" Width="Auto" VerticalAlignment="Top" Height="25" Background="#FFF0F0F0" BorderThickness="1" BorderBrush="#FF2E2E2E">
                <Canvas Margin="1,1,1,0" Width="Auto" VerticalAlignment="Top" Height="25" Background="Transparent">
                    <Button Click="MainWindow_Click" Margin="1,1,0,0" Width="55" Content="Home" Height="20" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" Background="#FFE3E3E3" BorderBrush="#FF6D6D6D"></Button>
                    <Button Click="StringTools_Click" Margin="60,0,0,0" Width="75" Content="String Tools" Height="23.3" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" Background="#FFFEFEFE" BorderBrush="#FF6D6D6D" BorderThickness="0.7,0.7,0.7,0"></Button>
                </Canvas>
            </Border>

            <TextBlock Grid.Column="1" Text="AC Directory: " FontSize="16" Margin="20,30,140,0" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="0,0,0,0" Width="Auto" Height="22" />
            <TextBox Grid.Column="1" x:Name="ACPath2" HorizontalAlignment="Right" VerticalAlignment="Top" Width="140" Height="22" FontSize="12" Margin="5,30,0,0" TextChanged="ACPath_TextChanged" />
            <Button Grid.Column="2" x:Name="PathDialog2" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="22" Margin="5,30,20,0" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="PathDialog_Click" Content=". . ." FontWeight="Bold" FontSize="11"/>

            <TextBlock Grid.Column="0" Text="Add Title" FontSize="18" Margin="20,25,20,20" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" Width="Auto" Height="22" FontFamily="Palatino Linotype" FontWeight="Bold" />
            <Button x:Name="AddTitleButton" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="22" Margin="20,50,20,20" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="AddTitleButton_Click" Content="Add" FontSize="14"/>
            <TextBox Grid.Column="0" x:Name="AddTitleInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="180" Height="22" FontSize="12" Margin="90,50,20,20" />

            <TextBlock Grid.Column="0" Text="Replace Spell" FontSize="18" Margin="20,75,20,20" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" Width="Auto" Height="22" FontFamily="Palatino Linotype" FontWeight="Bold" />
            <Button x:Name="ReplaceSpellButton" HorizontalAlignment="Left" VerticalAlignment="Top" Width="70" Height="22" Margin="20,100,20,20" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="ReplaceSpellButton_Click" Content="Replace" FontSize="14"/>
            <TextBox Grid.Column="0" TextChanged="SpellNameInput_Changed" x:Name="ReplaceSpellNameInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="105" Height="22" FontSize="12" Margin="165,100,20,20" Panel.ZIndex="1" Background="{x:Null}" />
            <TextBox Grid.Column="0" TextChanged="SpellDescInput_Changed" Grid.ColumnSpan="2" x:Name="ReplaceSpellDescInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="250" Height="22" FontSize="12" Margin="20,125,20,20" Panel.ZIndex="1" Background="{x:Null}" />
            <TextBox Grid.Column="0" TextChanged="SpellNumInput_Changed" x:Name="ReplaceSpellNumInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="22" FontSize="12" Margin="100,100,20,20" Panel.ZIndex="1" Background="{x:Null}" />
            <TextBlock x:Name="SpellIDPlaceholder" Grid.Column="0" Text="ID" FontSize="12" Margin="100,100,20,20" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,3,0,0" Width="60" Height="22" Foreground="#FF595959" Background="White" />
            <TextBlock x:Name="SpellNamePlaceholder" Grid.Column="0" Text="Name" FontSize="12" Margin="165,100,20,20" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,3,0,0" Width="105" Height="22" Foreground="#FF595959" Background="White" />
            <TextBlock x:Name="SpellDescPlaceholder" Grid.Column="0" Text="Description" FontSize="12" Margin="20,125,20,20" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,3,0,0" Width="250" Height="22" Foreground="#FF595959" Background="White" />

            <Border Grid.ColumnSpan="3" Grid.Column="0" BorderBrush="DarkGray" BorderThickness="2" Height="auto" Width="auto" Margin="10,300,10,10" CornerRadius="4,4,4,4">
                <ScrollViewer x:Name="ScrollViewerConsole2" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="OutputConsole2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="auto" Height="auto" FontSize="14" Margin="0,0,0,0" Text="{Binding ConsoleText}" Padding="5,3,5,5" Cursor="IBeam" FontFamily="Segoe UI Variable Text" TextWrapping="Wrap" Background="WhiteSmoke" IsReadOnly="True" IsUndoEnabled="False" />
                </ScrollViewer>
            </Border>

            <Button Click="TestStrings_Click" Width="70" Height="20" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,60,0,0" Content="Test Strings"></Button>
            <Button Click="AddStrings_Click" Width="40" Height="20" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="75,60,0,0" Content="Add"></Button>
            <Border x:Name="Test1" Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="#FF616161" BorderThickness="1" Height="200" Width="Auto" Margin="0,-50,10,0" Background="White" HorizontalAlignment="Stretch" VerticalAlignment="Center" CornerRadius="3,3,3,3">
                <ScrollViewer MinHeight="200" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="2,2,2,6">
                    <StackPanel x:Name="StringStackPanel" Orientation="Vertical" CanVerticallyScroll="True" CanHorizontallyScroll="False">

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
