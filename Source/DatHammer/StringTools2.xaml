<UserControl x:Class="DatHammer.StringTools2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DatHammer"
        mc:Ignorable="d">
    <UserControl.Resources>
        <RoutedUICommand x:Key="StringToolsWindow_Click"></RoutedUICommand>
        <RoutedUICommand x:Key="MainWindowWindow_Click"></RoutedUICommand>
    </UserControl.Resources>
    <UserControl.CommandBindings>
        <CommandBinding Command="{StaticResource StringToolsWindow_Click}" Executed="StringToolsWindow_Executed"></CommandBinding>
        <CommandBinding Command="{StaticResource MainWindowWindow_Click}" Executed="MainWindowWindow_Executed"></CommandBinding>
    </UserControl.CommandBindings>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Grid.ColumnSpan="3" Margin="1,1,1,0" Width="Auto" VerticalAlignment="Top" Height="25" Background="#FFF0F0F0" BorderThickness="1" BorderBrush="#FF2E2E2E">
            <Canvas Margin="1,1,1,0" Width="Auto" VerticalAlignment="Top" Height="25" Background="Transparent">
                <Button Click="MainWindowWindow_Click" Margin="1,0,0,0" Width="55" Content="Home" Height="20" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" Background="#FFE3E3E3" BorderBrush="#FF6D6D6D"></Button>
                <Button Click="StringToolsWindow_Click" Margin="60,0,0,0" Width="75" Content="String Tools" Height="20" VerticalAlignment="Center" HorizontalAlignment="Left" FontWeight="Bold" Background="#FFE3E3E3" BorderBrush="#FF6D6D6D"></Button>
            </Canvas>
        </Border>

        <TextBlock Grid.Column="1" Text="AC Directory: " FontSize="16" Margin="20,30,140,0" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="0,0,0,0" Width="Auto" Height="22" />
        <TextBox Grid.Column="1" x:Name="ACPath" HorizontalAlignment="Right" VerticalAlignment="Top" Width="140" Height="22" FontSize="12" Margin="5,30,0,0" TextChanged="ACPath_TextChanged" />
        <Button Grid.Column="2" x:Name="PathDialog" HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="22" Margin="5,30,20,0" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="PathDialog_Click" Content=". . ." FontWeight="Bold" FontSize="11"/>

        <TextBlock Grid.Column="0" Text="Add Title" FontSize="18" Margin="20,25,20,20" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" Width="Auto" Height="22" FontFamily="Palatino Linotype" FontWeight="Bold" />
        <Button x:Name="AddTitleButton" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="22" Margin="20,50,20,20" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="AddTitleButton_Click" Content="Add" FontSize="14"/>
        <TextBox Grid.Column="0" x:Name="AddTitleInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="180" Height="22" FontSize="12" Margin="90,50,20,20" />

        <TextBlock Grid.Column="0" Text="Replace Spell" FontSize="18" Margin="20,75,20,20" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,0,0,0" Width="Auto" Height="22" FontFamily="Palatino Linotype" FontWeight="Bold" />
        <Button x:Name="ReplaceSpellButton" HorizontalAlignment="Left" VerticalAlignment="Top" Width="70" Height="22" Margin="20,100,20,20" Background="#FFE3E3E3" BorderBrush="#FF222222" Foreground="Black" Click="ReplaceSpellButton_Click" Content="Replace" FontSize="14"/>
        <TextBox Grid.Column="0" TextChanged="SpellNameInput_Changed" x:Name="ReplaceSpellNameInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="105" Height="22" FontSize="12" Margin="165,100,20,20" Panel.ZIndex="1" Background="{x:Null}" />
        <TextBox Grid.Column="0" TextChanged="SpellDescInput_Changed" Grid.ColumnSpan="2" x:Name="ReplaceSpellDescInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="250" Height="22" FontSize="12" Margin="20,125,20,20" Panel.ZIndex="1" Background="{x:Null}" />
        <TextBox Grid.Column="0" TextChanged="SpellNumInput_Changed" x:Name="ReplaceSpellNumInput" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="22" FontSize="12" Margin="100,100,20,20" Panel.ZIndex="1" Background="{x:Null}" />
        <TextBlock x:Name="SpellIDPlaceholder" Grid.Column="0" Text="ID" FontSize="12" Margin="100,100,20,20" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,3,0,0" Width="60" Height="22" Foreground="#FF595959" Background="White" />
        <TextBlock x:Name="SpellNamePlaceholder" Grid.Column="0" Text="Name" FontSize="12" Margin="165,100,20,20" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,3,0,0" Width="105" Height="22" Foreground="#FF595959" Background="White" />
        <TextBlock x:Name="SpellDescPlaceholder" Grid.Column="0" Text="Description" FontSize="12" Margin="20,125,20,20" TextAlignment="Center" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="0,3,0,0" Width="250" Height="22" Foreground="#FF595959" Background="White" />

        <Border Grid.ColumnSpan="3" Grid.Column="0" BorderBrush="DarkGray" BorderThickness="2" Height="auto" Width="auto" Margin="10,300,10,10">
            <ScrollViewer x:Name="ScrollViewerConsole" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="OutputConsole" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="auto" Height="auto" FontSize="14" Margin="0, 0, 0, 0" Text="{Binding ConsoleText}" Padding="5, 3, 5, 5" Cursor="IBeam" FontFamily="Segoe UI Variable Text" TextWrapping="Wrap" Background="WhiteSmoke" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
